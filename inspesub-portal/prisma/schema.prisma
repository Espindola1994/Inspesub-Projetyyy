// INSPESUB Portal Corporativo - Schema Prisma
// Versão: 1.0.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  admin_master
  rh
  supervisor
  member
}

enum AccountStatus {
  pending
  active
  inactive
  rejected
  suspended
}

enum AttendanceStatus {
  worked
  day_off
  embarked
  disembarked
  training
  vacation
  medical_leave
  justified_absence
  not_informed
}

enum RdoStatus {
  pending
  submitted
  under_review
  approved
  rejected
}

enum DocumentCategory {
  certificate
  training
  aso
  internal
  contract
  identification
  other
}

enum AnnouncementCategory {
  hr
  operational
  training
  safety
  general
}

enum NotificationType {
  new_payslip
  pending_attendance
  account_approved
  account_rejected
  pending_rdo
  document_expiring
  new_announcement
  team_change
  general
}

enum AuditAction {
  account_created
  account_approved
  account_rejected
  login
  logout
  upload
  download
  attendance_marked
  attendance_edited
  attendance_closed
  profile_updated
  team_changed
  rdo_submitted
  rdo_approved
  rdo_rejected
  document_uploaded
  document_deleted
  announcement_created
  settings_changed
}

// ============================================
// AUTENTICAÇÃO (NextAuth compatível)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// USUÁRIOS
// ============================================

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole      @default(member)
  status        AccountStatus @default(pending)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  accounts          Account[]
  sessions          Session[]
  profile           EmployeeProfile?
  approvals         Approval[]
  uploadedPayslips  Payslip[]         @relation("PayslipUploader")
  receivedPayslips  Payslip[]         @relation("PayslipEmployee")
  attendanceRecords AttendanceRecord[]
  supervisedTeams   Team[]            @relation("TeamSupervisor")
  teamMemberships   TeamMember[]
  rdoRecords        RdoRecord[]       @relation("RdoAuthor")
  rdoReviews        RdoRecord[]       @relation("RdoReviewer")
  documents         Document[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  announcements     Announcement[]
  passwordResets    PasswordReset[]

  @@map("users")
}

model EmployeeProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  registration      String?   @unique
  position          String?
  department        String?
  phone             String?
  birthDate         DateTime?
  address           String?
  addressStreet     String?
  addressNumber     String?
  addressNeighborhood String?
  addressCity       String?
  addressState      String?
  addressCountry    String?
  emergencyContact  String?
  emergencyPhone    String?
  admissionDate     DateTime?
  avatarUrl         String?
  bio               String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("employee_profiles")
}

model Approval {
  id          String        @id @default(cuid())
  userId      String
  reviewedBy  String?
  status      AccountStatus @default(pending)
  notes       String?
  requestedAt DateTime      @default(now())
  reviewedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("approvals")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ============================================
// EQUIPES
// ============================================

model Team {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  description  String?
  operation    String?
  supervisorId String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supervisor        User?              @relation("TeamSupervisor", fields: [supervisorId], references: [id])
  members           TeamMember[]
  rdoRecords        RdoRecord[]
  attendanceRecords AttendanceRecord[]

  @@map("teams")
}

model TeamMember {
  id       String    @id @default(cuid())
  teamId   String
  userId   String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  isActive Boolean   @default(true)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

// ============================================
// PRESENÇA
// ============================================

model AttendanceRecord {
  id          String           @id @default(cuid())
  userId      String
  teamId      String?
  date        DateTime         @db.Date
  status      AttendanceStatus @default(not_informed)
  observation String?
  closedMonth Boolean          @default(false)
  closedAt    DateTime?
  closedBy    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id])

  @@unique([userId, date])
  @@map("attendance_records")
}

model AttendanceMonthClosing {
  id       String   @id @default(cuid())
  userId   String
  year     Int
  month    Int
  closedAt DateTime @default(now())
  closedBy String

  @@unique([userId, year, month])
  @@map("attendance_month_closings")
}

// ============================================
// CONTRACHEQUES
// ============================================

model Payslip {
  id           String    @id @default(cuid())
  employeeId   String
  uploadedById String
  year         Int
  month        Int
  fileUrl      String
  fileName     String
  fileSize     Int?
  mimeType     String?
  description  String?
  readAt       DateTime?
  uploadedAt   DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee   User @relation("PayslipEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("PayslipUploader", fields: [uploadedById], references: [id])

  @@unique([employeeId, year, month])
  @@map("payslips")
}

// ============================================
// RDO
// ============================================

model RdoRecord {
  id                    String    @id @default(cuid())
  date                  DateTime  @db.Date
  teamId                String
  authorId              String
  reviewerId            String?
  status                RdoStatus @default(pending)
  location              String
  vessel                String?
  serviceDescription    String    @db.Text
  workedHours           Float
  operationalConditions String?   @db.Text
  equipmentUsed         String?   @db.Text
  occurrences           String?   @db.Text
  responsibleName       String
  responsibleSignature  String?
  reviewNotes           String?
  reviewedAt            DateTime?
  submittedAt           DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  team     Team      @relation(fields: [teamId], references: [id])
  author   User      @relation("RdoAuthor", fields: [authorId], references: [id])
  reviewer User?     @relation("RdoReviewer", fields: [reviewerId], references: [id])
  files    RdoFile[]

  @@unique([teamId, date])
  @@map("rdo_records")
}

model RdoFile {
  id         String   @id @default(cuid())
  rdoId      String
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  uploadedAt DateTime @default(now())

  rdo RdoRecord @relation(fields: [rdoId], references: [id], onDelete: Cascade)

  @@map("rdo_files")
}

// ============================================
// DOCUMENTOS
// ============================================

model Document {
  id           String           @id @default(cuid())
  userId       String
  uploadedById String?
  category     DocumentCategory @default(other)
  title        String
  description  String?
  fileUrl      String
  fileName     String
  fileSize     Int?
  mimeType     String?
  issuedAt     DateTime?
  expiresAt    DateTime?
  isExpired    Boolean          @default(false)
  tags         String[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ============================================
// COMUNICADOS
// ============================================

model Announcement {
  id          String               @id @default(cuid())
  authorId    String
  title       String
  content     String               @db.Text
  category    AnnouncementCategory @default(general)
  isPinned    Boolean              @default(false)
  isPublished Boolean              @default(true)
  publishedAt DateTime?
  expiresAt   DateTime?
  targetRoles String[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@map("announcements")
}

// ============================================
// NOTIFICAÇÕES
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================
// AUDITORIA
// ============================================

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      AuditAction
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ============================================
// CONFIGURAÇÕES
// ============================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  group     String   @default("general")
  label     String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("settings")
}
